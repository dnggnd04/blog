# ══════════════════════════════════════════════════════════════
#  Blog App — Environment Variables
#  Sao chép file này thành .env và điền đầy đủ giá trị
#  KHÔNG commit file .env lên git!
# ══════════════════════════════════════════════════════════════

# ── Database (dùng cho Docker Compose + Backend) ──────────────
DB_USER=
DB_PASSWORD=
DB_ROOT_PASSWORD=
# Format: mysql+pymysql://USER:PASSWORD@db/blog
DATABASE_URL=

# ── Backend App (FastAPI) ─────────────────────────────────────
API_PREFIX=/api
# Khóa bí mật để ký JWT token — tạo bằng: openssl rand -hex 32
SECRET_KEY=
# Các origin được phép gọi API (CORS)
# Ví dụ: http://yourdomain.com,http://192.168.1.100
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:80

# ── Frontend (React build-time — baked vào bundle) ───────────
# URL gọi API (để trống nếu dùng nginx proxy /api → backend)
REACT_APP_API_URL=/api
# WebSocket URL — thay IP VM của bạn vào đây
REACT_APP_WS_URL=ws://YOUR_VM_IP

# ── Monitoring Dashboard ──────────────────────────────────────
MONITORING_PORT=8080

# ── AWS S3 (Tùy chọn — chỉ điền nếu dùng upload ảnh lên S3) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=ap-southeast-1

# ── Telegram Notification (Tùy chọn) ─────────────────────────
# Nhận thông báo deploy qua Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=